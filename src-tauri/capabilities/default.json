{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "CCT 默认权限配置",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:window:allow-theme",
    "core:window:allow-set-theme",
    "shell:allow-open",
    "shell:allow-stdin-write",
    "shell:allow-spawn",
    "shell:allow-kill",
    "dialog:default",
    "fs:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "exec-sh",
          "cmd": "/bin/sh",
          "args": true
        },
        {
          "name": "exec-bash",
          "cmd": "/bin/bash",
          "args": true
        },
        {
          "name": "exec-zsh",
          "cmd": "/bin/zsh",
          "args": true
        }
      ]
    }
  ]
}
